<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="test_barcode_service.BarcodeTestApp" owl="1">
        <div class="o_action o_view_controller">
            <div class="h-100 bg-white p-4">
                <h1>Test Hybrid Devices (Keyboard vs WebSocket)</h1>
                
                <div class="d-flex align-items-center mt-3 mb-4">
                    <div t-attf-class="spinner-grow spinner-grow-sm me-2 text-{{ state.wsConnected ? 'success' : 'danger' }}" role="status" t-if="!state.isReading"></div>
                    <div class="spinner-border spinner-border-sm me-2 text-warning" role="status" t-if="state.isReading"></div>
                    <strong t-attf-class="text-{{ state.isReading ? 'warning' : (state.wsConnected ? 'success' : 'danger') }} me-4">
                        Local Server: <t t-esc="state.isReading ? 'Reading Devices...' : state.wsStatus"/>
                    </strong>
                    
                    <div class="d-flex align-items-center me-3 border-start ps-3">
                        <label class="me-2 small fw-bold text-muted">WS Timeout:</label>
                        <input type="number" class="form-control form-control-sm me-2" style="width: 80px;" t-model.number="state.wsDuration" t-att-disabled="state.isReading"/>
                        <button class="btn btn-primary btn-sm" 
                                t-att-disabled="!state.wsConnected || state.isReading" 
                                t-on-click="() => this.triggerRFID('WS')">
                            <i class="fa fa-wifi me-1"></i> Send (WS)
                        </button>
                    </div>

                    <div class="d-flex align-items-center border-start ps-3">
                        <label class="me-2 small fw-bold text-muted">KB Timeout:</label>
                        <input type="number" class="form-control form-control-sm me-2" style="width: 80px;" t-model.number="state.keyboardDuration" t-att-disabled="state.isReading"/>
                        <button class="btn btn-secondary btn-sm" 
                                t-att-disabled="!state.wsConnected || state.isReading" 
                                t-on-click="() => this.triggerRFID('KEYBOARD')">
                            <i class="fa fa-keyboard-o me-1"></i> Send (KB)
                        </button>
                    </div>
                </div>

                <div class="alert alert-warning py-2 mb-3" t-if="state.isReading">
                    <i class="fa fa-spinner fa-spin me-2"/> <b>Xin chờ:</b> Đang thu thập dữ liệu từ thiết bị phần cứng... Hệ thống sẽ bung cảnh báo nếu quá thời gian.
                </div>

                <div class="row">
                    <div class="col-md-6 border-end">
                        <p class="text-muted">
                            <b>Option 1 (Keyboard):</b> Set cursor anywhere and use scanner or WinForms App to send keystrokes.
                        </p>
                        <p class="text-muted">
                            <b>Option 2 (WebSocket):</b> Click "Trigger RFID" above, or use the WinForms App "Send via WebSocket" button.
                        </p>
                        
                        <div class="alert alert-info mt-4">
                            <h3>Last Scanned: <t t-esc="state.lastScannedBarcode || 'None'"/></h3>
                        </div>
                    </div>
                
                    <div class="col-md-6 px-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4>Scan History <t t-if="state.scanHistory.length > 0">(<t t-esc="state.scanHistory.length"/>)</t></h4>
                            <button class="btn btn-sm btn-outline-secondary" t-on-click="() => state.scanHistory = []">Clear</button>
                        </div>
                        <div style="max-height: 400px; overflow-y: auto;" t-if="state.scanHistory.length > 0">
                            <ul class="list-group">
                                <t t-foreach="state.scanHistory" t-as="item" t-key="item_index">
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <div class="d-flex align-items-center">
                                            <span t-attf-class="badge rounded-pill me-3 text-bg-{{ item.source == 'WebSocket' ? 'success' : 'secondary' }}" style="width: 100px;">
                                                <t t-esc="item.source"/>
                                            </span>
                                            <b><t t-esc="item.barcode"/></b>
                                        </div>
                                        <span class="text-muted small">
                                            <t t-esc="item.time"/>
                                        </span>
                                    </li>
                                </t>
                            </ul>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </t>
</templates>
