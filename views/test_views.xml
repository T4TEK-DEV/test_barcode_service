<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================ -->
    <!--              COMPREHENSIVE TEST FORM                             -->
    <!-- ================================================================ -->

    <record id="view_barcode_test_comprehensive_form" model="ir.ui.view">
        <field name="name">t4.barcode.test.comprehensive.form</field>
        <field name="model">t4.barcode.test</field>
        <field name="arch" type="xml">
            <form string="Comprehensive Test (HID + Passive)">
                <header />
                <div class="alert alert-info" role="alert">
                    <strong>Comprehensive Component Testing:</strong>
                    <ul class="mb-0 mt-1">
                        <li><b>Active HID (Tuần tự):</b> Quét thực tế hoặc dùng Simulator đẩy Data → Sẽ nhảy field theo đúng `data-auto-input-order`.</li>
                        <li><b>Passive KB (Giả lập Nút bấm):</b> Sử dụng các nút bấm giả lập ở Header và thanh Control Panel để lấy data từ Keyboard Emulator. Trình diễn đầy đủ các cấu hình `timeout`, `toggle`, `position`, `action_start/stop`.</li>
                    </ul>
                </div>
                <sheet>
                    <group>
                        <group string="Dữ liệu Tuần Tự (data-auto-input-order)">
                            <field name="name"         data-auto-input-order="0" />
                            <field name="barcode"      data-auto-input-order="1" />
                            <field name="serial"       data-auto-input-order="2" />
                            <field name="lot_number"   data-auto-input-order="3" />
                            <field name="product_code" data-auto-input-order="4" />
                            <field name="rfid_tag"     data-auto-input-order="5" />
                        </group>
                        <group string="Ép kiểu Dữ Liệu">
                            <field name="quantity"     data-auto-input-order="6" />
                            <field name="weight"       data-auto-input-order="7" />
                        </group>
                    </group>
                    <group>
                        <group string="Các trường thông thường (Nhập tay)">
                            <field name="manufacturer_part" />
                            <field name="supplier_part" />
                            <field name="location_barcode" />
                        </group>
                        <group string="Thông tin thêm">
                            <field name="scan_count" />
                            <field name="is_verified" />
                            <field name="note" placeholder="Ghi chú thêm..." />
                        </group>
                    </group>
                    <group string="Text nhiều dòng (textarea)">
                        <field name="description" data-auto-input-order="8" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================ -->
    <!--              COMPREHENSIVE TEST LIST                             -->
    <!-- ================================================================ -->

    <record id="view_barcode_test_comprehensive_list" model="ir.ui.view">
        <field name="name">t4.barcode.test.comprehensive.list</field>
        <field name="model">t4.barcode.test</field>
        <field name="arch" type="xml">
            <list string="Comprehensive Test (List)" editable="bottom">
                <field name="name"         data-auto-input-order="0" />
                <field name="barcode"      data-auto-input-order="1" />
                <field name="serial"       data-auto-input-order="2" />
                <field name="rfid_tag"     data-auto-input-order="3" />
                <field name="quantity"     data-auto-input-order="4" />
                <field name="scan_count" />
                <field name="note" />
            </list>
        </field>
    </record>

    <!-- ================================================================ -->
    <!--                         ACTION                                   -->
    <!-- ================================================================ -->

    <record id="action_test_barcode_comprehensive" model="ir.actions.act_window">
        <field name="name">Comprehensive Test</field>
        <field name="res_model">t4.barcode.test</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_barcode_test_comprehensive_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_barcode_test_comprehensive_form')})]"/>
        <field name="context">{
            't4_auto_input_enabled': True,
            't4_passive_buttons': [
                {
                    'id': 'rfid_reader',
                    'title': 'Quét RFID',
                    'icon': 'fa-wifi',
                    'position': 'status_bar',
                    'url': 'ws://localhost:9001/scan',
                    'timeout': 5000,
                    'toggle': True,
                    'action_start': 'READ_RFID_KEYBOARD',
                    'action_stop': 'STOP_RFID_KEYBOARD',
                },
                {
                    'id': 'cam_infinite',
                    'title': 'Camera (Vô hạn)',
                    'icon': 'fa-camera',
                    'position': 'control_panel',
                    'url': 'ws://localhost:9003/scan',
                    'timeout': 0,
                    'toggle': True,
                    'action_start': 'START_CAMERA',
                    'action_stop': 'STOP_CAMERA',
                },
                {
                    'id': 'nfc_oneshot',
                    'title': 'NFC Quẹt thẻ',
                    'icon': 'fa-credit-card',
                    'position': 'status_bar',
                    'url': 'ws://localhost:9004/scan',
                    'timeout': 1000,
                    'toggle': False,
                    'action_start': 'READ_NFC',
                },
            ],
        }</field>
    </record>

</odoo>
