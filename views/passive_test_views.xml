<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================ -->
    <!--                         FORM VIEW                                -->
    <!-- ================================================================ -->

    <record id="view_barcode_test_passive_form" model="ir.ui.view">
        <field name="name">t4.barcode.test.passive.form</field>
        <field name="model">t4.barcode.test</field>
        <field name="arch" type="xml">
            <form string="Test Passive HID Bridge (KB Mode)">
                <header />
                <div class="alert alert-info" role="alert">
                    <strong>Test Passive Device (Keyboard Emulation):</strong>
                    <ol class="mb-0 mt-1">
                        <li>Chay <b>C# BarcodeSimulator</b> (hoac T4HidBridge) → port <b>9001</b></li>
                        <li>Mo view nay → browser tu ket noi WebSocket <code>ws://localhost:9001</code></li>
                        <li>Nhan nut <b>Scan</b> tren header → gui <code>READ_RFID_KEYBOARD</code></li>
                        <li>Server doc thiet bi → go data qua Keyboard (Ctrl+V)</li>
                        <li>Barcode service bat paste → split delimiter <code>|</code> → dien field tuan tu</li>
                    </ol>
                    <small class="text-muted">
                        Context: <code>t4_auto_input_enabled=True</code> + <code>t4_passive_buttons=[...]</code><br/>
                        <b>toggle=True:</b> Nut bat/tat, tu dung sau <code>timeout</code> ms ·
                        <b>toggle=False:</b> Nhan 1 lan → doc 1 lan
                    </small>
                </div>
                <sheet>
                    <group>
                        <group string="Ket qua quet (tuan tu)">
                            <field name="rfid_tag"   data-auto-input-order="0" />
                            <field name="barcode"    data-auto-input-order="1" />
                            <field name="serial"     data-auto-input-order="2" />
                        </group>
                        <group string="Thong tin">
                            <field name="name" />
                            <field name="scan_count" />
                            <field name="note" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================ -->
    <!--                         LIST VIEW                                -->
    <!-- ================================================================ -->

    <record id="view_barcode_test_passive_list" model="ir.ui.view">
        <field name="name">t4.barcode.test.passive.list</field>
        <field name="model">t4.barcode.test</field>
        <field name="arch" type="xml">
            <list string="Test Passive HID Bridge (List)" editable="top">
                <field name="rfid_tag" data-auto-input-order="0" />
                <field name="barcode"  data-auto-input-order="1" />
                <field name="serial"   data-auto-input-order="2" />
                <field name="name" />
                <field name="note" />
            </list>
        </field>
    </record>

    <!-- ================================================================ -->
    <!--                         ACTIONS                                  -->
    <!-- ================================================================ -->

    <!-- 1. Form: RFID Reader — toggle mode (tu dung sau 5s) -->
    <record id="action_barcode_test_single_rfid" model="ir.actions.act_window">
        <field name="name">Form — RFID Reader (KB)</field>
        <field name="res_model">t4.barcode.test</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_barcode_test_passive_form"/>
        <field name="context">{
            't4_auto_input_enabled': True,
            't4_passive_buttons': [
                {
                    'id': 'rfid_reader',
                    'title': 'Quet RFID',
                    'icon': 'fa-wifi',
                    'url': 'http://localhost:9001/scan',
                    'timeout': 5000,
                    'toggle': True,
                },
            ],
        }</field>
    </record>

    <!-- 2. Form: NFC — one-shot -->
    <record id="action_barcode_test_single_weight" model="ir.actions.act_window">
        <field name="name">Form — NFC One-shot (KB)</field>
        <field name="res_model">t4.barcode.test</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_barcode_test_passive_form"/>
        <field name="context">{
            't4_auto_input_enabled': True,
            't4_passive_buttons': [
                {
                    'id': 'nfc',
                    'title': 'NFC',
                    'icon': 'fa-credit-card',
                    'url': 'http://localhost:9004/scan',
                    'timeout': 3000,
                    'toggle': False,
                },
            ],
        }</field>
    </record>

    <!-- 3. List: RFID — moi the tao 1 dong moi -->
    <record id="action_barcode_test_list_rfid" model="ir.actions.act_window">
        <field name="name">List — RFID (KB)</field>
        <field name="res_model">t4.barcode.test</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_barcode_test_passive_list"/>
        <field name="context">{
            't4_auto_input_enabled': True,
            't4_passive_buttons': [
                {
                    'id': 'rfid_reader',
                    'title': 'Quet RFID',
                    'icon': 'fa-wifi',
                    'url': 'http://localhost:9001/scan',
                    'timeout': 5000,
                    'toggle': True,
                },
            ],
        }</field>
    </record>

    <!-- 4. Form: Multi device — RFID + Camera + NFC -->
    <record id="action_barcode_test_multi_device" model="ir.actions.act_window">
        <field name="name">Form — RFID + Camera + NFC (KB)</field>
        <field name="res_model">t4.barcode.test</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_barcode_test_passive_form"/>
        <field name="context">{
            't4_auto_input_enabled': True,
            't4_passive_buttons': [
                {
                    'id': 'rfid',
                    'title': 'RFID',
                    'icon': 'fa-wifi',
                    'url': 'http://localhost:9001/scan',
                    'timeout': 5000,
                    'toggle': True,
                },
                {
                    'id': 'cam',
                    'title': 'Camera',
                    'icon': 'fa-camera',
                    'url': 'http://localhost:9003/scan',
                    'timeout': 3000,
                    'toggle': True,
                },
                {
                    'id': 'nfc',
                    'title': 'NFC',
                    'icon': 'fa-credit-card',
                    'url': 'http://localhost:9004/scan',
                    'timeout': 3000,
                    'toggle': False,
                },
            ],
        }</field>
    </record>

</odoo>
