<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================ -->
    <!--              HYBRID FORM: Active HID + Passive KB Mode            -->
    <!-- ================================================================ -->

    <record id="view_barcode_test_hybrid_form" model="ir.ui.view">
        <field name="name">t4.barcode.test.hybrid.form</field>
        <field name="model">t4.barcode.test</field>
        <field name="arch" type="xml">
            <form string="Test Hybrid — HID + RFID KB (Form)">
                <header />
                <div class="alert alert-warning" role="alert">
                    <strong>Test KET HOP: Active HID + Passive Keyboard Emulation</strong>
                    <ul class="mb-0 mt-1">
                        <li><b>Active (HID):</b> Quet barcode ban phim → tu dien tuan tu theo <code>data-auto-input-order</code></li>
                        <li><b>Passive (KB):</b> Nhan nut Scan tren header → C# server go data qua Keyboard</li>
                        <li>Ca hai deu di qua <b>barcode service</b> → <b>auto-input</b> dien tuan tu</li>
                    </ul>
                    <small class="text-muted">
                        Context: <code>t4_auto_input_enabled=True</code> + <code>t4_passive_buttons=[...]</code>
                    </small>
                </div>
                <sheet>
                    <group>
                        <group string="Tuan tu (HID + Passive chung)">
                            <field name="name"         data-auto-input-order="0" />
                            <field name="barcode"      data-auto-input-order="1" />
                            <field name="serial"       data-auto-input-order="2" />
                            <field name="product_code" data-auto-input-order="3" />
                        </group>
                        <group string="Tiep tuc tuan tu">
                            <field name="rfid_tag"     data-auto-input-order="4" />
                            <field name="lot_number"   data-auto-input-order="5" />
                            <field name="quantity"     data-auto-input-order="6" />
                            <field name="weight" />
                        </group>
                    </group>
                    <group>
                        <group string="Thong tin bo sung">
                            <field name="scan_count" />
                            <field name="is_verified" />
                        </group>
                        <group string="Ghi chu">
                            <field name="note"
                                   placeholder="Ghi chu..." />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================ -->
    <!--              HYBRID LIST: Active HID + Passive KB Mode            -->
    <!-- ================================================================ -->

    <record id="view_barcode_test_hybrid_list" model="ir.ui.view">
        <field name="name">t4.barcode.test.hybrid.list</field>
        <field name="model">t4.barcode.test</field>
        <field name="arch" type="xml">
            <list string="Test Hybrid — HID + RFID KB (List)" editable="top">
                <field name="name"         data-auto-input-order="0" />
                <field name="barcode"      data-auto-input-order="1" />
                <field name="serial"       data-auto-input-order="2" />
                <field name="rfid_tag"     data-auto-input-order="3" />
                <field name="scan_count" />
                <field name="note" />
            </list>
        </field>
    </record>

    <!-- ================================================================ -->
    <!--                         ACTIONS                                  -->
    <!-- ================================================================ -->

    <!-- Hybrid Form: HID sequential + RFID KB toggle -->
    <record id="action_barcode_test_hybrid_form" model="ir.actions.act_window">
        <field name="name">Form — HID + RFID (KB)</field>
        <field name="res_model">t4.barcode.test</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_barcode_test_hybrid_form"/>
        <field name="context">{
            't4_auto_input_enabled': True,
            't4_passive_buttons': [
                {
                    'id': 'rfid_reader',
                    'title': 'Quet RFID',
                    'icon': 'fa-wifi',
                    'url': 'ws://localhost:9001/scan',
                    'timeout': 5000,
                    'toggle': True,
                    'action_start': 'READ_RFID_KEYBOARD',
                    'action_stop': 'STOP_RFID_KEYBOARD',
                },
            ],
        }</field>
    </record>

    <!-- Hybrid List: HID sequential + RFID KB toggle -->
    <record id="action_barcode_test_hybrid_list" model="ir.actions.act_window">
        <field name="name">List — HID + RFID (KB)</field>
        <field name="res_model">t4.barcode.test</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_barcode_test_hybrid_list"/>
        <field name="context">{
            't4_auto_input_enabled': True,
            't4_passive_buttons': [
                {
                    'id': 'rfid_reader',
                    'title': 'Quet RFID',
                    'icon': 'fa-wifi',
                    'url': 'ws://localhost:9001/scan',
                    'timeout': 5000,
                    'toggle': True,
                    'action_start': 'READ_RFID_KEYBOARD',
                    'action_stop': 'STOP_RFID_KEYBOARD',
                },
            ],
        }</field>
    </record>

</odoo>
