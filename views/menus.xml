<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Client action for BarcodeTestApp OWL component -->
    <record id="action_test_barcode" model="ir.actions.client">
        <field name="name">Test Barcode</field>
        <field name="tag">test_barcode_service.main_app</field>
    </record>

    <!-- Settings action -->
    <record id="action_test_barcode_settings" model="ir.actions.act_window">
        <field name="name">Barcode Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="context">{'module': 'test_barcode_service'}</field>
    </record>

    <!-- ================================================================ -->
    <!--                         ROOT MENU                                -->
    <!-- ================================================================ -->

    <menuitem id="menu_test_barcode_root"
              name="Test Barcode"
              sequence="10" />

    <!-- Barcode Service (existing OWL app) -->
    <menuitem id="menu_test_barcode"
              name="Barcode Service"
              parent="menu_test_barcode_root"
              action="action_test_barcode"
              sequence="10" />

    <!-- ================================================================ -->
    <!--                    COMPREHENSIVE TEST                            -->
    <!-- ================================================================ -->

    <menuitem id="menu_comprehensive_test"
              name="Comprehensive Test (HID + KB)"
              parent="menu_test_barcode_root"
              action="action_test_barcode_comprehensive"
              sequence="20" />

    <!-- ================================================================ -->
    <!--                         SETTINGS                                 -->
    <!-- ================================================================ -->

    <menuitem id="menu_test_barcode_settings"
              name="Settings"
              parent="menu_test_barcode_root"
              action="action_test_barcode_settings"
              sequence="90" />

</odoo>
